# ── A2A Hub (back/) ───────────────────────────────────────────────────────────
# Port the hub listens on when running locally
HUB_PORT=8000

# ── Frontend (front/) ─────────────────────────────────────────────────────────
# Copy front/.env.example → front/.env and fill in values there.
# The keys below are a summary; see front/.env.example for the full list.

OLLAMA_BASE_URL=http://localhost:11434

# LLM API keys (leave blank to disable that provider)
ANTHROPIC_API_KEY=
CHATGPT_API_KEY=
GEMINI_CHAT_API_KEY=

# Microsoft SSO (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CLIENT_TENANT_ID=
MICROSOFT_REDIRECT_URI=
